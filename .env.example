# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in your real values.
#   cp .env.example .env
# The ".env" file is git-ignored so your secrets never get committed.
# ----------------------------------------------------------------------------

# REQUIRED: your Discord bot token (see README for how to obtain it)
DISCORD_TOKEN=your-bot-token-here

# OPTIONAL: a single guild (server) ID.
# If set, slash commands are registered to just that server and appear
# instantly (great for development). If left empty, commands are registered
# globally and can take up to ~1 hour to propagate.
GUILD_ID=

# OPTIONAL: path to the SQLite database file (defaults to poker.db)
DB_PATH=poker.db
